# CourtListener API Token (get free at https://www.courtlistener.com/sign-in/)
COURTLISTENER_API_TOKEN=

# Transport: stdio (default) or http
TRANSPORT=stdio

# HTTP server settings (only used when TRANSPORT=http)
HOST=0.0.0.0
PORT=8000

# Comma-separated allowed CORS origins (HTTP mode only)
# Default allows basic-host dev client. Add proxy origins as needed.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
